<UserControl x:Class="ExamFinalePt1NR.Views.UsersControls.Livre.UpdateLivreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ExamFinalePt1NR.Views.UsersControls.Livre"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="White">
    <Grid>
        <Grid.ColumnDefinitions>
        <ColumnDefinition Width="100"/>
        <ColumnDefinition Width="100"/>
        <ColumnDefinition Width="100"/>
        <ColumnDefinition Width="20"/>
        <ColumnDefinition Width="100"/>
        <ColumnDefinition Width="100"/>
        <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
    </Grid.RowDefinitions>

    <!--linge 1-->
    <TextBlock Grid.Column="3" Grid.ColumnSpan="3" Grid.Row="0" 
                   Text="Modifier un livre"
                   HorizontalAlignment="Center"
                   FontSize="17"
                   Foreground="#2e9ed4"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>

    <!--linge 2-->
    <TextBlock Grid.Column="0" Grid.Row="1" Text="Id du livre :"
                   HorizontalAlignment="Center"
                   FontSize="15"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>

    <TextBox x:Name="TxtId" Grid.Row="1" Grid.Column="1" Height="35"/>

    <Button Grid.Column="2" Grid.Row="1"
                Background="#2e9ed4"
                Content="Chercher"
                Foreground="White"
                FontSize="14"
                FontWeight="Bold"
                Height="35"/>

    <!--Ligne 3-->
    <TextBlock Grid.Column="0" Grid.Row="2" Text="Titre :"
                   HorizontalAlignment="Center"
                   FontSize="15"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>

    <TextBox x:Name="TxtTitre" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="6" Height="35"/>
    <!--ligne 4-->
    <TextBlock Grid.Column="0" Grid.Row="3" Text="Auteur :"
                   HorizontalAlignment="Center"
                   FontSize="15"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>

    <TextBox x:Name="TxtAuteur" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="6" Height="35"/>
    <!--ligne 5-->
    <TextBlock Grid.Column="0" Grid.Row="4" Text="Catégorie :"
                   HorizontalAlignment="Center"
                   FontSize="15"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>

    <TextBox x:Name="TxtCategorie" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="6" Height="35"/>
    <!--ligne 6-->
    <TextBlock Grid.Column="0" Grid.Row="5" Text="Quantité :"
HorizontalAlignment="Center"
FontSize="15"
FontWeight="Bold"
VerticalAlignment="Center"/>

    <TextBox x:Name="TxtQuantite" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="6" Height="35"/>
    <!--ligne 7-->
    <Button Grid.Column="4" Grid.Row="7"
                Background="#f4006e"
                Content="Modifier"
                Foreground="White"
                FontSize="14"
                FontWeight="Bold"
                Height="35"
                Margin="0,0,10,0"/>

    <Button Grid.Column="5" Grid.Row="7"
        Background="#94a4a5"
        Content="Annuler"
        Foreground="White"
        FontSize="14"
        FontWeight="Bold"
        Height="35"
        Margin="10,0,0,0" Click="BtnAnnuler_Click"/>

    </Grid>
</UserControl>
