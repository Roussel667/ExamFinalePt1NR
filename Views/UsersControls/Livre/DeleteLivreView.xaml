<UserControl x:Class="ExamFinalePt1NR.Views.UsersControls.Livre.DeleteLivreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ExamFinalePt1NR.Views.UsersControls.Livre"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="750" Background="White">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>


        <!-- Titre -->
        <TextBlock Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="3"
            Text="Supprimer un livre"
            FontSize="22"
            FontWeight="Bold"
            HorizontalAlignment="Center"
            Margin="0,10,0,10"
            Foreground="Red"/>


        <!--Section Id-->
        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="Id du Livre :"
                   FontSize="16"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
        <TextBox x:Name="TxtId" Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="4" Height="30" Margin="5,5" />


        <!--Bouton-->
        <Button Width="100" 
                Height="30" 
                Background="#e64b3b" 
                Content="Supprimer"
                FontWeight="Bold"
                FontSize="12"
                Foreground="White" 
                Click="BtnClick_Supprimer"
                Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" Margin="0,0,10,0"/>

        <Button Width="100" 
                Height="30"
                Background="#94a4a5" 
                Content="Annuler"
                FontWeight="Bold"
                FontSize="12"
                Foreground="White" 
                Click="BtnAnnuler_Click"
                Grid.Row="3" Grid.Column="3" Grid.ColumnSpan="2" Margin="10,0,0,0"/>




    </Grid>
</UserControl>
