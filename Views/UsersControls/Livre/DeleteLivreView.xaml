<UserControl x:Class="ExamFinalePt1NR.Views.UsersControls.Livre.DeleteLivreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ExamFinalePt1NR.Views.UsersControls.Livre"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <!-- Titre -->
        <TextBlock Grid.Row="0"
            Text="Supprimer un livre"
            FontSize="22"
            FontWeight="Bold"
            HorizontalAlignment="Center"
            Margin="0,10,0,10"
            Foreground="Red"
                   Grid.Column="1"/>


        <!--Section Id-->
        <TextBlock Grid.Row="2"
                   Text="Id du Livre :"
                   Grid.Column="0"
                   FontSize="16"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>
        <TextBox x:Name="TxtId" Grid.Column="1"
                 Grid.Row="1"
                 HorizontalAlignment="Left"
                 Width="630" Margin="0,15,0,15" Grid.RowSpan="3"/>


        <!--Bouton-->
        <Button Width="100" 
                Height="30" 
                Grid.Row="4" 
                Grid.Column="1"
                Background="#e64b3b" 
                Content="Supprimer"
                FontWeight="Bold"
                FontSize="12"
                Foreground="White" 
                Click="BtnClick_Supprimer"
                Margin="0,0,200,0"/>

        <Button Width="100" 
                Height="30" 
                Grid.Row="4" 
                Grid.Column="1"
                Background="#94a4a5" 
                Content="Annuler"
                FontWeight="Bold"
                FontSize="12"
                Foreground="White" 
                Click="BtnClick_Annuler"
                Margin="100,0,0,0"/>




    </Grid>
</UserControl>
