<UserControl x:Class="ExamFinalePt1NR.Views.UsersControls.Livre.AddLivreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ExamFinalePt1NR.Views.UsersControls.Livre"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="750" Background="White">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        
        <!--linge 1-->
        <TextBlock Grid.Column="2" Grid.ColumnSpan="3" Grid.Row="0" 
                   Text="Ajouter un Livre"
                   HorizontalAlignment="Center"
                   FontSize="17"
                   Foreground="#32ad5f"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>

        <!--linge 2-->
        <TextBlock Grid.Column="0" Grid.Row="1" Text="Titre :"
                   HorizontalAlignment="Center"
                   FontSize="15"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>
        
        <TextBox x:Name="TxtTitre" Grid.Row="1" Grid.Column="1" 
                 Grid.ColumnSpan="5" Height="30" Margin="5,10"/>
        
        
        
        <!--Ligne 3-->
        <TextBlock Grid.Column="0" Grid.Row="2" Text="Auteur :"
                   HorizontalAlignment="Center"
                   FontSize="15"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>

        <TextBox x:Name="TxtAuteur" Grid.Row="2" Grid.Column="1"
                 Grid.ColumnSpan="5" Height="30" Margin="5,10"/>
        <!--ligne 4-->
        <TextBlock Grid.Column="0" Grid.Row="3" Text="ISBN :"
                   HorizontalAlignment="Center"
                   FontSize="15"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>

        <TextBox x:Name="TxtISBn" Grid.Row="3" Grid.Column="1" 
                 Grid.ColumnSpan="5" Height="30" Margin="5,10"/>
        <!--ligne 5-->
        <TextBlock Grid.Column="0" Grid.Row="4" Text="Prix :"
                   HorizontalAlignment="Center"
                   FontSize="15"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>

        <TextBox x:Name="TxtPrix" Grid.Row="4" Grid.Column="1" 
                 Grid.ColumnSpan="5" Height="30" Margin="5,10"/>
        <!--ligne 6-->
        <TextBlock Grid.Column="0" Grid.Row="5" Text="Catégorie :"
                   HorizontalAlignment="Center"
                   FontSize="15"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>

        <ComboBox x:Name="CboCateg" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="5" Margin="5,10">
            <ComboBoxItem Name="Litterature">Litterature</ComboBoxItem>
            <ComboBoxItem Name="Science_Fiction">Science-Fiction</ComboBoxItem>
            <ComboBoxItem Name="Classique">Classique</ComboBoxItem>
        </ComboBox>

        <!--ligne 7-->
        <TextBlock Grid.Column="0" Grid.Row="6" Text="Quantité :"
           HorizontalAlignment="Center"
           FontSize="15"
           FontWeight="Bold"
           VerticalAlignment="Center"/>
        
        <TextBox x:Name="TxtQuantte" Grid.Row="6" Grid.Column="1" 
                 Grid.ColumnSpan="1" Height="30" Margin="5,10"/>



        <!--ligne 8-->
        <Button Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="8"
                Background="#32ad5f"
                Content="Ajouter le livre"
                Foreground="White"
                FontSize="14"
                FontWeight="Bold"
                Height="35"
                Margin="0,0,10,0" Click="BtnAjotuer_Click"/>

        <Button Grid.Column="4" Grid.ColumnSpan="2" Grid.Row="9"
        Background="#f4006e"
        Content="Annuler"
        Foreground="White"
        FontSize="14"
        FontWeight="Bold"
        Height="35"
        Margin="10,0,0,0" Click="BtnAnnuler_Click"/>

        

    </Grid>
</UserControl>
